# xiaocai 部署环境变量示例
# 使用时复制为 .env 并填写实际值

# ============================================
# 命名与模式
# ============================================
INSTANCE_PROJECT=inst-xiaocai-dev
INSTANCE_NETWORK_NAME=inst-xiaocai-net-dev
# devlib overlay 开关（kernel 已属于 instance baseline）
ENABLE_DEVLIB_FLARE=false

# ============================================
# 服务端口配置
# ============================================
# API 宿主机端口（文档用途；compose 已固定写死为 28001）
API_PORT=28001

# Web 宿主机端口（文档用途；compose 已固定写死为 23001）
WEB_PORT=23001

# xiaocai 壳层 iframe 的 flare-core 入口（固定避开 9000）
VITE_FLARE_CORE_ENTRY_URL=http://localhost:29000/

# FLARE Kernel 宿主机端口（文档用途；compose 已固定写死为 28000）
KERNEL_PORT=28000

# FLARE Kernel 路径配置
# instance baseline 默认使用: inst-xiaocai-kernel
# 使用宿主机本地 kernel 时: host.docker.internal
# 如需直连远端真实 kernel，可配置完整地址（示例: http://47.103.102.80:8000）
KERNEL_RUNTIME_MODE=http
KERNEL_BASE_URL=http://inst-xiaocai-kernel:8000
KERNEL_HOST=inst-xiaocai-kernel
KERNEL_RUN_PATH=/kernel/run
KERNEL_STREAM_PATH=/kernel/stream

# Nginx 宿主机端口（文档用途；compose 已固定写死）
NGINX_PORT=10080
NGINX_HTTPS_PORT=10443

# ============================================
# 基础设施宿主机端口（文档用途；compose 已固定写死）
# ============================================
POSTGRES_PORT=25432
REDIS_PORT=26379
QDRANT_HTTP_PORT=26333
QDRANT_GRPC_PORT=26334

# ============================================
# JWT 认证配置
# ============================================
# JWT 签名密钥（生产环境务必使用强密钥）
INSTANCE_JWT_SECRET=your-secret-key-change-this-in-production

# ============================================
# 认证模式配置
# ============================================
# 是否使用 Mock 认证（生产建议 false；本地联调可手动改为 true）
MOCK_AUTH=false

# 真实认证验证 URL（生产环境配置）
REAL_AUTH_VERIFY_URL=https://your-host-app.com/api/verify

# root 认证配置（当 MOCK_AUTH=false 且未接宿主认证时使用）
ROOT_AUTH_TOKEN=
ROOT_USER_ID=root

# ============================================
# xiaocai runtime switches
# ============================================
ENABLE_LOCAL_ORCHESTRATION_FALLBACK=false

# FLARE Kernel 配置
# ============================================
# 如果 FLARE kernel 在外部运行，配置其地址
# EXTERNAL_KERNEL_HOST=kernel.example.com
# EXTERNAL_KERNEL_PORT=28000

# ============================================
# 数据库配置（如果需要）
# ============================================
# 实例数据库（推荐 PostgreSQL）
POSTGRES_DB=xiaocai
POSTGRES_USER=xiaocai
POSTGRES_PASSWORD=xiaocai_dev_password
STORAGE_DB_URL=postgresql://xiaocai:xiaocai_dev_password@inst-xiaocai-postgres:5432/xiaocai
# SQLite 回退路径（仅 STORAGE_DB_URL 为空时生效）
STORAGE_DB_PATH=/data/xiaocai-instance.db
UPLOAD_ROOT=/data/uploads
REDIS_URL=redis://inst-xiaocai-redis:6379/0
QDRANT_URL=http://inst-xiaocai-qdrant:6333
FLARE_POSTGRES_DSN=postgresql://xiaocai:xiaocai_dev_password@inst-xiaocai-postgres:5432/xiaocai
FLARE_REDIS_URL=redis://inst-xiaocai-redis:6379/0
FLARE_QDRANT_URL=http://inst-xiaocai-qdrant:6333
FLARE_SOURCE_UPLOAD_DIR=/data/sources
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=["pdf","doc","docx","xls","xlsx","csv","txt","md","png","jpg","jpeg","webp"]
ENABLED_MODES=["auto","requirement_canvas","analysis_mode","intelligent_sourcing"]
DAILY_MESSAGE_LIMIT=0
DAILY_PROJECT_MESSAGE_LIMIT=0

# ============================================
# 部署后数据可见性 Smoke Check
# ============================================
# 防止上线后因默认模式/过滤字段变化导致历史项目或会话不可见。
DATA_VISIBILITY_SMOKE_ENABLED=false
DATA_VISIBILITY_SMOKE_API_BASE_URL=http://localhost:28001
DATA_VISIBILITY_SMOKE_AUTH_MODE=mock
DATA_VISIBILITY_SMOKE_USER_ID=
DATA_VISIBILITY_SMOKE_FUNCTION_TYPE=auto
DATA_VISIBILITY_SMOKE_MIN_PROJECTS=1
DATA_VISIBILITY_SMOKE_MIN_TOTAL_SESSIONS=1
# 格式: project_id:min_sessions,project_id:min_sessions
DATA_VISIBILITY_SMOKE_PROJECT_SPECS=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=xiaocai
# DB_USER=xiaocai
# DB_PASSWORD=secure-password

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO

# ============================================
# Domain Pack
# ============================================
FLARE_INSTANCE_ID=xiaocai
FLARE_DOMAIN_PACK_DEFAULT_DOMAIN=xiaocai
FLARE_DOMAIN_PACK_VERSION=default

# ============================================
# FLARE Runtime / LLM
# Mirrors the current FLARE test runtime.
# ============================================
LLM_PROVIDER_BACKEND=apipro
APIPRO_API_KEY=your_apipro_api_key
APIPRO_BASE_URL=https://api.wenwen-ai.com/v1
APIPRO_MODEL=gpt-5.5
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_MODEL=qwen3.7-max
MODEL_ROUTER_DEFAULT_MODEL=apipro/gpt-5.5
MODEL_ROUTER_PRIMARY_BY_INTENT_JSON=
MODEL_ROUTER_FALLBACK_BY_INTENT_JSON=
LLM_PROVIDER_MAX_RETRIES=3
LLM_PROVIDER_FAILOVER_ENABLED=true
LLM_PROVIDER_FAILOVER_BACKEND=dashscope
LLM_PROVIDER_FAILOVER_MODEL=qwen3.7-max
LLM_PROVIDER_FAILOVER_LONG_CONTEXT_MODEL=qwen-long-latest
LLM_PROVIDER_FAILOVER_LONG_CONTEXT_MIN_CHARS=120000
LLM_PROVIDER_TIMEOUT_SECONDS=240
SOURCE_IMAGE_UNDERSTANDING_ENABLED=true
SOURCE_IMAGE_UNDERSTANDING_PROVIDER=dashscope
SOURCE_IMAGE_UNDERSTANDING_MODEL=qwen3.5-omni-flash
SOURCE_IMAGE_UNDERSTANDING_TIMEOUT_SECONDS=60
STRUCTURED_REASONING_ENABLED=true

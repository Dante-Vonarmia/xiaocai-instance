{
  "$schema": "./schema/manifest-schema.json",
  "version": "0.1.0",
  "name": "xiaocai",
  "displayName": "小采 - 采购助手",
  "description": "智能采购需求梳理与供应商寻源助手",

  "comment": "部署清单 - 定义 xiaocai 实例的组成和配置",

  "components": {
    "adapters": {
      "http_api": {
        "path": "../adapters/http_api",
        "type": "fastapi",
        "port": 8001,
        "description": "HTTP API 适配器，提供认证和对话接口"
      }
    },

    "frame": {
      "web": {
        "path": "../frame/web",
        "type": "react",
        "port": 3000,
        "description": "Web 前端壳，集成 FLARE chat UI"
      }
    },

    "domain_pack": {
      "path": "../domain-packs",
      "type": "config",
      "description": "采购领域配置包（domain-packs）",
      "includes": [
        "branding/",
        "cards/",
        "category-fields/",
        "schema/",
        "terminology/",
        "workflows/"
      ]
    }
  },

  "dependencies": {
    "external": [
      {
        "name": "FLARE kernel",
        "type": "service",
        "required": true,
        "description": "FLARE 核心服务，提供 7 Engine 能力"
      },
      {
        "name": "FLARE packages",
        "type": "npm",
        "required": true,
        "packages": [
          "@flare/chat-ui",
          "@flare/chat-core",
          "@flare/engines",
          "@flare/kernel",
          "@flare/storage-adapters"
        ],
        "description": "FLARE 前端和核心包"
      }
    ]
  },

  "deployment": {
    "method": "docker-compose",
    "config_file": "compose.instance.yml",
    "env_file": ".env",
    "services": [
      "inst-xiaocai-postgres",
      "inst-xiaocai-redis",
      "inst-xiaocai-qdrant",
      "inst-xiaocai-api",
      "inst-xiaocai-web",
      "inst-xiaocai-nginx"
    ]
  },

  "business_capabilities": [
    {
      "name": "需求梳理",
      "description": "收集和确认采购需求",
      "workflow": "requirement-collection",
      "reference": "../docs/discussions/phase-1-procurement-product-logic.md"
    },
    {
      "name": "智能寻源",
      "description": "根据需求搜索和推荐供应商",
      "workflow": "supplier-search",
      "reference": "../docs/discussions/phase-1-procurement-product-logic.md"
    },
    {
      "name": "知识库管理",
      "description": "上传和管理采购相关文档",
      "reference": "../docs/discussions/phase-1-knowledge-base.md"
    },
    {
      "name": "用户管理",
      "description": "用户认证和权限控制",
      "reference": "../docs/discussions/phase-1-member-management.md"
    }
  ],

  "metadata": {
    "created_at": "2026-03-24",
    "updated_at": "2026-03-24",
    "authors": ["xiaocai team"],
    "license": "Proprietary"
  }
}

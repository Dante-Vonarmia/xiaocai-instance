# xiaocai 部署环境变量示例
# 使用时复制为 .env 并填写实际值

# ============================================
# 命名与模式
# ============================================
INSTANCE_PROJECT=inst-xiaocai-dev
INSTANCE_NETWORK_NAME=inst-xiaocai-net-dev
ENABLE_DEVLIB_FLARE=false
COMPOSE="docker compose"

# ============================================
# 服务端口配置
# ============================================
# API 服务端口
API_PORT=8001

# Web 前端端口
WEB_PORT=3001
# xiaocai 壳层 iframe 的 flare-core 入口
VITE_FLARE_CORE_ENTRY_URL=http://localhost:9000/

# FLARE Kernel 端口
KERNEL_PORT=18002

# FLARE Kernel 路径配置
# 开发使用 devlib compose 时: devlib-flare-kernel
# 使用宿主机本地 kernel 时: host.docker.internal
# 如需直连远端真实 kernel，可配置完整地址（示例: http://47.103.102.80:8000）
KERNEL_RUNTIME_MODE=http
KERNEL_BASE_URL=http://host.docker.internal:18002
KERNEL_HOST=host.docker.internal
KERNEL_RUN_PATH=/kernel/run
KERNEL_STREAM_PATH=/kernel/stream

# Nginx 端口
NGINX_PORT=80
NGINX_HTTPS_PORT=443

# ============================================
# 基础设施端口
# ============================================
POSTGRES_PORT=5432
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ============================================
# JWT 认证配置
# ============================================
# JWT 签名密钥（生产环境务必使用强密钥）
INSTANCE_JWT_SECRET=dev-secret-key-with-32-chars-min-1234

# ============================================
# 认证模式配置
# ============================================
# 是否使用 Mock 认证（开发环境设置为 true）
MOCK_AUTH=true

# 真实认证验证 URL（生产环境配置）
REAL_AUTH_VERIFY_URL=http://flare-kernel:8000/auth/verify

# root 认证配置（当 MOCK_AUTH=false 且未接宿主认证时使用）
ROOT_AUTH_TOKEN=root-local-dev-token
ROOT_USER_ID=root

# ============================================
# FLARE Kernel 配置
# ============================================
# 如果 FLARE kernel 在外部运行，配置其地址
# EXTERNAL_KERNEL_HOST=kernel.example.com
# EXTERNAL_KERNEL_PORT=8000

# ============================================
# 数据库配置（如果需要）
# ============================================
# 实例数据库（推荐 PostgreSQL）
POSTGRES_DB=xiaocai
POSTGRES_USER=xiaocai
POSTGRES_PASSWORD=xiaocai_dev_password
STORAGE_DB_URL=postgresql://xiaocai:xiaocai_dev_password@inst-xiaocai-postgres:5432/xiaocai
# SQLite 回退路径（仅 STORAGE_DB_URL 为空时生效）
STORAGE_DB_PATH=/data/xiaocai-instance.db
UPLOAD_ROOT=/data/uploads
REDIS_URL=redis://inst-xiaocai-redis:6379/0
QDRANT_URL=http://inst-xiaocai-qdrant:6333
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=["pdf","doc","docx","xls","xlsx","txt"]
ENABLED_MODES=["auto","requirement_canvas","intelligent_sourcing"]
DAILY_MESSAGE_LIMIT=0
DAILY_PROJECT_MESSAGE_LIMIT=0
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=xiaocai
# DB_USER=xiaocai
# DB_PASSWORD=secure-password

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO

# ============================================
# LLM Provider（百炼）
# ============================================
LLM_PROVIDER_BACKEND=dashscope
DASHSCOPE_API_KEY=sk-5c916bd4f0ca4b1aa66bd982b0dd5e90
# 默认使用百炼 OpenAI 兼容接口
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

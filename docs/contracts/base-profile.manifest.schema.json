{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "base-profile.manifest.schema.json",
  "title": "Base Profile Manifest",
  "description": "Registry contract for standard product base profiles.",
  "type": "object",
  "required": ["registry_version", "profiles"],
  "properties": {
    "registry_version": {
      "type": "string",
      "minLength": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile_id",
          "domain",
          "version",
          "status",
          "entrypoints"
        ],
        "properties": {
          "profile_id": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "deprecated"]
          },
          "entrypoints": {
            "type": "object",
            "required": [
              "schema",
              "field_dictionary",
              "workflow",
              "terminology",
              "category_fields",
              "cards",
              "contracts",
              "scenarios"
            ],
            "properties": {
              "schema": { "type": "string", "minLength": 1 },
              "field_dictionary": { "type": "string", "minLength": 1 },
              "workflow": { "type": "string", "minLength": 1 },
              "terminology": { "type": "string", "minLength": 1 },
              "category_fields": { "type": "string", "minLength": 1 },
              "cards": { "type": "string", "minLength": 1 },
              "contracts": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "minItems": 1
              },
              "scenarios": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "allOf": [
          {
            "not": {
              "required": ["private_data"]
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false
}

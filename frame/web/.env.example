# xiaocai Frame Web 环境变量示例
# 使用时复制为 .env 并填写实际值

# API 基础 URL
# 开发环境可以使用 vite proxy，设置为 /api
# 生产环境设置为完整 URL
VITE_API_BASE_URL=/api

# 默认项目 ID（用于会话绑定/设置页）
VITE_DEFAULT_PROJECT_ID=project-default

# 是否启用前端模拟登录入口；生产小程序接入保持 false
VITE_ENABLE_MOCK_AUTH=false

# 公开测试账号入口（需要后端 PUBLIC_TEST_AUTH_ENABLED 同步开启）
VITE_ENABLE_PUBLIC_TEST_AUTH=false
VITE_PUBLIC_TEST_USER_ID=public-test-user
VITE_PUBLIC_TEST_DISPLAY_NAME=云鹤AI公开测试用户

# core 入口 URL（必填；例如本地 flare-chat-core: http://localhost:9000/）
VITE_FLARE_CORE_ENTRY_URL=http://localhost:29000/

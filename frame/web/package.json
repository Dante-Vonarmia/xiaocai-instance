{
  "name": "xiaocai-frame-web",
  "version": "0.1.0",
  "private": true,
  "description": "xiaocai 前端壳 - 基于 FLARE packages",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@flare/chat-core": "npm:flare-chat-core@0.2.0",
    "@flare/chat-ui": "npm:flare-chat-ui@^0.2.0",
    "@tanstack/react-query": "^5.17.0",
    "antd": "^6.2.2",
    "axios": "^1.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "flare-chat-core": "0.2.0",
    "flare-canvas-ui": "0.2.0",
    "flare-generative-ui": "0.2.0",
    "flare-chat-ui": {
      "flare-chat-core": "0.2.0",
      "flare-canvas-ui": "0.2.0",
      "flare-generative-ui": "0.2.0"
    }
  }

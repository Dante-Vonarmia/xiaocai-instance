# xiaocai Instance API 配置示例
# 使用时复制为 .env 并填写实际值

# ============================================
# API 服务配置
# ============================================
API_HOST=0.0.0.0
API_PORT=8001

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ============================================
# JWT 认证配置
# ============================================
# JWT 签名密钥（生产环境务必使用强密钥）
INSTANCE_JWT_SECRET=your-secret-key-change-this-in-production

# JWT 过期时间（分钟，默认 7 天）
JWT_EXPIRE_MINUTES=10080

# ============================================
# FLARE Kernel 配置
# ============================================
# Kernel 服务地址和端口
KERNEL_HOST=localhost
KERNEL_PORT=8000

# ============================================
# Domain Pack 配置
# ============================================
# domain-pack 根目录路径
FLARE_DOMAIN_PACK_ROOT=/Users/dantevonalcatraz/Development/procurement-agents/domain-pack

# SQLite 存储路径
STORAGE_DB_PATH=/tmp/xiaocai-instance.db
STORAGE_DB_URL=
UPLOAD_ROOT=/tmp/xiaocai-instance-uploads
UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=["pdf","doc","docx","xls","xlsx","txt"]
ENABLED_MODES=["auto","requirement_canvas","analysis_mode","intelligent_sourcing"]
DAILY_MESSAGE_LIMIT=0
DAILY_PROJECT_MESSAGE_LIMIT=0

# ============================================
# 认证模式配置
# ============================================
# 是否使用 Mock 认证（开发环境设置为 true）
MOCK_AUTH=true

# 真实认证验证 URL（生产环境配置）
REAL_AUTH_VERIFY_URL=https://your-host-app.com/api/verify

# 采购中国小程序登录凭证校验配置
CAIGOU_CHINA_AUTH_VERIFY_URL=https://your-caigou-china-host.com/api/auth/verify-credential
CAIGOU_CHINA_APP_ID=yunhe_ai
CAIGOU_CHINA_APP_SECRET=

# 公开测试账号（生产如需给测试方直接进入，可开启；仍只允许固定用户）
PUBLIC_TEST_AUTH_ENABLED=false
PUBLIC_TEST_USER_ID=public-test-user
PUBLIC_TEST_DISPLAY_NAME=云鹤AI公开测试用户

# root 认证配置（当 MOCK_AUTH=false 且未接宿主认证时使用）
ROOT_AUTH_TOKEN=
ROOT_USER_ID=root
